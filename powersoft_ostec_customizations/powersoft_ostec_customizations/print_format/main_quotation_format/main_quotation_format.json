 "css": ".fields-table-structured\n.fields-table-structured tr,\n.fields-table-structured tr th,\n.fields-table-structured tr td{\n    /*border: none !important;*/\n}\n.table-structured\n.table-structured tr,\n.table-structured tr th,\n.table-structured tr td{\n    /*border: none !important;*/\n}\n\n.fields-table-structured-labels{\n    font-weight:bold;\n    font-size:14px;\n}\n.fields-table-structured-values{\n    font-size:14px;\n}\n.table-structured-labels{\n    font-weight:bold;\n    text-align: center !important;\n    font-size:11px;\n}\n.table-structured-values{\n    font-size:10px;\n}",
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "Quotation",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "{{letter_head}}\r\n\r\n<br>\r\n<br>\r\n\r\n<table style=\"\" class=\"fields-table-structured\">\r\n\t<tbody>\r\n\t\t<tr>\r\n\t\t\t<td class=\"fields-table-structured-values\" style=\"width:25%; padding:1px !important; margin:1px !important;\">\r\n\t\t\t\t<div style=\"\">{{doc.party_name}}</div>\r\n\t\t\t</td>\r\n\t\t\t<td class=\"fields-table-structured-values\" style=\"width:25%; padding:1px !important; margin:1px !important;\">\r\n\t\t\t\t<div style=\"\"></div>\r\n\t\t\t</td>\r\n\t\t\t<td class=\"fields-table-structured-labels\" style=\"width:25%; padding:1px !important; margin:1px !important;\">\r\n\t\t\t\t<div style=\"\">Pro Forma No:</div>\r\n\t\t\t</td>\r\n\t\t\t<td class=\"fields-table-structured-values\" style=\"width:25%; padding:1px !important; margin:1px !important;\">\r\n\t\t\t\t<div style=\"\">{{doc.name}}</div>\r\n\t\t\t</td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td class=\"fields-table-structured-values\" style=\"padding:1px !important; margin:1px !important;\">\r\n\t\t\t\t<div style=\"\"><br>{{doc.address_display}}</div>\r\n\t\t\t</td>\r\n\t\t\t<td class=\"fields-table-structured-values\" style=\"padding:1px !important; margin:1px !important;\">\r\n\t\t\t\t<div style=\"\"></div>\r\n\t\t\t</td>\r\n\t\t\t<td class=\"fields-table-structured-labels\" style=\"padding:1px !important; margin:1px !important;\">\r\n\t\t\t\t<div style=\"\">Pro Forma Date:</div>\r\n\t\t\t</td>\r\n\t\t\t<td class=\"fields-table-structured-values\" style=\"padding:1px !important; margin:1px !important;\">\r\n\t\t\t\t<div style=\"\">{{doc.get_formatted(\"transaction_date\")}}</div>\r\n\t\t\t</td>\r\n\t\t</tr>\r\n\t</tbody>\r\n</table>\r\n<br />\r\n{% if doc.custom_quotation_type == 'License Renewal' %}\r\n<table class=\"table-structured\" border=\"1\">\r\n\t<thead>\r\n\t\t<tr>\r\n\t\t\t<th style=\"width: 5%\" class=\"table-structured-labels\">Qty</th>\r\n\t\t\t<th style=\"width: 15%\" class=\"table-structured-labels\">Part Number</th>\r\n\t\t\t<th style=\"width: 20%\" class=\"table-structured-labels\">Description</th>\r\n\t\t\t<th style=\"width: 15%\" class=\"table-structured-labels\">Serial No</th>\r\n\t\t\t<th style=\"width: 12%\" class=\"table-structured-labels\">Unit Cost</th>\r\n\t\t\t<th style=\"width: 11%\" class=\"table-structured-labels\">Total Year 1</th>\r\n{% if doc.custom_total_year_2 > 0 %}<th style=\"width: 11%\" class=\"table-structured-labels\">Total Year 2</th>{% endif %}\r\n{% if doc.custom_total_year_3 > 0 %}<th style=\"width: 11%\" class=\"table-structured-labels\">Total Year 3</th>{% endif %}\r\n\t\t</tr>\r\n\t</thead>\r\n\t<tbody>\r\n\t\t{% for row in doc.custom_license_renewal_items %}\r\n\t\t<tr>\r\n\t\t\t<td class=\"table-structured-values text-right\">{{row.qty}}</td>\r\n\t\t\t<td class=\"table-structured-values\">{{row.part_number}}</td>\r\n\t\t\t<td class=\"table-structured-values\">{{row.description}}</td>\r\n\t\t\t<td class=\"table-structured-values\">{{row.custom_serial_no}}</td>\r\n\t\t\t<td class=\"table-structured-values text-right\">\r\n\t\t\t\t{{row.get_formatted(\"rate\")}}\r\n\t\t\t</td>\r\n\t\t\t<td class=\"table-structured-values text-right\">\r\n\t\t\t\t{{row.get_formatted(\"amount\")}}\r\n\t\t\t</td>\r\n\t\t\t{% if doc.custom_total_year_2 > 0 %}\r\n\t\t\t<td class=\"table-structured-values text-right\">\r\n\t\t\t\t{{row.get_formatted(\"year_total_2\")}}\r\n\t\t\t</td>{% endif %}\r\n\t\t\t{% if doc.custom_total_year_3 > 0 %}\r\n\t\t\t<td class=\"table-structured-values text-right\">\r\n\t\t\t\t{{row.get_formatted(\"year_total_3\")}}\r\n\t\t\t</td>{% endif %}\r\n\t\t\t\r\n\t\t</tr>\r\n\t\t{% endfor %}\r\n\t</tbody>\r\n</table>\r\n{% elif doc.custom_quotation_type == 'Standard Quotation' %}\r\n<table class=\"table-structured\" border=\"1\">\r\n\t<thead>\r\n\t\t<tr>\r\n\t\t\t<th style=\"width: 2%\" class=\"table-structured-labels\">S.No</th>\r\n\t\t\t<th style=\"width: 10%\" class=\"table-structured-labels\">Qty</th>\r\n\t\t\t<th style=\"width: 25%\" class=\"table-structured-labels\">Part Number</th>\r\n\t\t\t<th style=\"width: 30%\" class=\"table-structured-labels\">Description</th>\r\n\t\t\t<th style=\"width: 20%\" class=\"table-structured-labels\">Unit Cost</th>\r\n\t\t\t<th style=\"width: 23%\" class=\"table-structured-labels\">Total</th>\r\n\t\t</tr>\r\n\t</thead>\r\n\t<tbody>\r\n\t\t{% for row in doc.custom_standard_quotation_items %}\r\n\t\t<tr>\r\n\t\t\t<td class=\"table-structured-values\">{{row.idx}}</td>\r\n\t\t\t<td class=\"table-structured-values text-right\">{{row.qty}}</td>\r\n\t\t\t<td class=\"table-structured-values\">{{row.item_name}}</td>\r\n\t\t\t<td class=\"table-structured-values\">{{row.description}}</td>\r\n\t\t\t<td class=\"table-structured-values text-right\">\r\n\t\t\t\t{{row.get_formatted(\"rate\")}}\r\n\t\t\t</td>\r\n\t\t\t<td class=\"table-structured-values text-right\">\r\n\t\t\t\t{{row.get_formatted(\"amount\")}}\r\n\t\t\t</td>\r\n\t\t</tr>\r\n\t\t{% endfor %}\r\n\t</tbody>\r\n</table>\r\n{% endif %}\r\n<br />\r\n<br />\r\n<table style=\"\" class=\"fields-table-structured\">\r\n\t<tbody>\r\n\t\t{% if doc.custom_quotation_type == 'License Renewal' %}\r\n    \t\t<tr>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\"width:20%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\"></div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\"width:20%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\"></div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-labels text-right\" style=\"width:20%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">Year 1</div>\r\n    \t\t\t</td>\r\n    \t\t\t{% if doc.custom_total_year_2 > 0 %}\r\n    \t\t\t<td class=\"fields-table-structured-labels text-right\" style=\"width:20%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">Year 2</div>\r\n    \t\t\t</td>{% endif %}\r\n    \t\t\t{% if doc.custom_total_year_3 > 0 %}\r\n    \t\t\t<td class=\"fields-table-structured-labels text-right\" style=\"width:20%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">Year 3</div>\r\n    \t\t\t</td>\r\n    \t\t\t{% endif %}\r\n    \t\t</tr>\r\n    \t\t<tr>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\" padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\"></div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\" padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">Sub Total [1] {{ doc.currency }}</div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\" padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{doc.get_formatted(\"total\")}}</div>\r\n    \t\t\t</td>\r\n    \t\t\t{% if doc.custom_total_year_2 > 0 %}\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\" padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{doc.get_formatted(\"custom_total_year_2\")}}</div>\r\n    \t\t\t</td>{% endif %}\r\n    \t\t\t{% if doc.custom_total_year_3 > 0 %}\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\" padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{doc.get_formatted(\"custom_total_year_3\")}}</div>\r\n    \t\t\t</td>{% endif %}\r\n    \t\t</tr>\r\n    \t\t\r\n    \t\t\r\n    \t\t{% for i in range(doc.taxes | len) %}\r\n    \t\t {% set t_row1 = doc.taxes[i] %}\r\n    \t\t {% set t_row2 = doc.custom_sales_taxes_and_charges_year_2[i] %}\r\n    \t\t {% set t_row3 = doc.custom_sales_taxes_and_charges_year_3[i] %}\r\n    \t\t<tr>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\" padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\"></div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\" padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{t_row1.description}}</div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\" padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{t_row1.get_formatted(\"tax_amount\")}}</div>\r\n    \t\t\t</td>\r\n    \t\t\t{% if doc.custom_total_year_2 > 0 %}\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\" padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{t_row2.get_formatted(\"tax_amount\")}}</div>\r\n    \t\t\t</td>{% endif %}\r\n    \t\t\t{% if doc.custom_total_year_3 > 0 %}\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\" padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{t_row3.get_formatted(\"tax_amount\")}}</div>\r\n    \t\t\t</td>{% endif %}\r\n    \t\t</tr>\r\n    \t\t{% endfor %}\r\n    \t\t<tr>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\"padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\"></div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\"padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">Total {{ doc.currency }}</div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\"padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{doc.get_formatted(\"grand_total\")}}</div>\r\n    \t\t\t</td>\r\n    \t\t\t{% if doc.custom_total_year_2 > 0 %}\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\"padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{doc.get_formatted(\"custom_grand_total_year_2\")}}</div>\r\n    \t\t\t</td>{% endif %}\r\n    \t\t\t{% if doc.custom_total_year_3 > 0 %}\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\"padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{doc.get_formatted(\"custom_grand_total_year_3\")}}</div>\r\n    \t\t\t</td>{% endif %}\r\n    \t\t</tr>\r\n    \t\t{% if doc.custom_quotation_type == 'License Renewal' and doc.custom_total_year_2 > 0 %}\r\n    \t\t<tr>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\"padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\"></div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\"padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">Grand Total (All Years)</div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\"padding:1px !important; margin:1px !important; font-weight: bold; font-size: 13px; border-top: 1px solid #000; border-bottom: 2px double #000;\" colspan=\"{{ 1 + (1 if doc.custom_total_year_2 > 0 else 0) + (1 if doc.custom_total_year_3 > 0 else 0) }}\">\r\n    \t\t\t\t<div style=\"\">{{ doc.get_formatted(\"custom_grand_total_all_years\") }}</div>\r\n    \t\t\t</td>\r\n    \t\t</tr>\r\n    \t\t{% endif %}\r\n\t\t{% else %}\r\n    \t\t<tr>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\"width:25%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\"></div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-values\" style=\"width:25%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\"></div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\"width:25%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">Sub Total [1] {{ doc.currency }}</div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\"width:25%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{doc.get_formatted(\"total\")}}</div>\r\n    \t\t\t</td>\r\n    \t\t</tr>\r\n    \t\t{% for t_row in doc.taxes %}\r\n    \t\t<tr>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\"width:25%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\"></div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-values\" style=\"width:25%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\"></div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\"width:25%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{t_row.description}}</div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\"width:25%; padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{t_row.get_formatted(\"tax_amount\")}}</div>\r\n    \t\t\t</td>\r\n    \t\t</tr>\r\n    \t\t{% endfor %}\r\n    \t\t<tr>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\"padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\"></div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-values\" style=\"padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\"></div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-labels\" style=\"padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">Total {{ doc.currency }}</div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"fields-table-structured-values text-right\" style=\"padding:1px !important; margin:1px !important;\">\r\n    \t\t\t\t<div style=\"\">{{doc.get_formatted(\"grand_total\")}}</div>\r\n    \t\t\t</td>\r\n    \t\t</tr>\r\n\t\t{% endif %}\r\n\t</tbody>\r\n</table>\r\n<br />\r\n<br />\r\n{% if doc.terms %}\r\n<p><b>Note:</b></p>\r\n<div>{{doc.terms}}</div>\r\n{% endif %}\r\n",
